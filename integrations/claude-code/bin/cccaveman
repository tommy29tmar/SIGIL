#!/usr/bin/env bash
# cccaveman — Claude Code with Caveman prose prompt at system level.
#
# Mirror of cccflint but uses prompts/primitive_english.txt (the Caveman
# baseline) instead of flint_thinking_system_prompt.txt. Used for
# benchmark comparison: Caveman vs Flint on identical Claude Code
# sessions.
#
# Prompt resolution order:
#   1. $CAVEMAN_PROMPT_FILE env var
#   2. $HOME/.claude/primitive_english.txt (installer location)
#   3. $(dirname $0)/../../prompts/primitive_english.txt (repo checkout)

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_prompt_file() {
  if [ -n "${CAVEMAN_PROMPT_FILE:-}" ] && [ -f "$CAVEMAN_PROMPT_FILE" ]; then
    echo "$CAVEMAN_PROMPT_FILE"
    return
  fi
  local candidate="$HOME/.claude/primitive_english.txt"
  if [ -f "$candidate" ]; then
    echo "$candidate"
    return
  fi
  candidate="$script_dir/../../../prompts/primitive_english.txt"
  if [ -f "$candidate" ]; then
    echo "$candidate"
    return
  fi
  return 1
}

prompt_file="$(resolve_prompt_file)" || {
  echo "cccaveman: primitive_english.txt not found." >&2
  exit 1
}

prompt_body="$(cat "$prompt_file")"
exec claude --append-system-prompt "$prompt_body" "$@"
