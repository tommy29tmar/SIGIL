#!/usr/bin/env bash
# cccflint-mcp — Claude Code with Flint thinking-mode + MCP tool enforcement.
#
# Extends cccflint: injects the thinking-mode-MCP system prompt (which tells
# the model to call `submit_flint_ir` for IR-shape tasks instead of emitting
# free-text IR) AND spawns the Flint MCP server via --mcp-config.
#
# With this mode the IR emitted by Claude is schema-validated at API level:
# the model cannot emit malformed atoms or suffix-form tokens — the API
# rejects invalid tool calls. Parser-pass on IR outputs ≈ 100% by construction.
#
# Prompt resolution order:
#   1. $FLINT_THINKING_MCP_PROMPT_FILE env var (explicit override)
#   2. $HOME/.claude/flint_thinking_mcp_system_prompt.txt (installer location)
#   3. $(dirname $0)/../flint_thinking_mcp_system_prompt.txt (repo checkout)
#
# MCP config resolution order:
#   1. $FLINT_MCP_CONFIG_FILE env var
#   2. $HOME/.claude/flint-mcp-config.json
#   3. $(dirname $0)/../mcp-config.json
#
# Usage:
#   cccflint-mcp                           # interactive session
#   cccflint-mcp -p "your prompt"          # non-interactive
#
# The default `claude` command and `cccflint` remain untouched; cccflint-mcp
# is a separate third binary. Users pick the level of enforcement they want.

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_file() {
  local name="$1"; shift
  for candidate in "$@"; do
    if [ -n "$candidate" ] && [ -f "$candidate" ]; then
      echo "$candidate"
      return
    fi
  done
  echo "cccflint-mcp: $name not found" >&2
  echo "Searched:" >&2
  for candidate in "$@"; do
    echo "  $candidate" >&2
  done
  return 1
}

prompt_file="$(resolve_file "thinking-mode-MCP prompt" \
  "${FLINT_THINKING_MCP_PROMPT_FILE:-}" \
  "$HOME/.claude/flint_thinking_mcp_system_prompt.txt" \
  "$script_dir/../flint_thinking_mcp_system_prompt.txt")" || exit 1

mcp_config_file="$(resolve_file "MCP config" \
  "${FLINT_MCP_CONFIG_FILE:-}" \
  "$HOME/.claude/flint-mcp-config.json" \
  "$script_dir/../mcp-config.json")" || exit 1

prompt_body="$(cat "$prompt_file")"
exec claude --append-system-prompt "$prompt_body" --mcp-config "$mcp_config_file" "$@"
