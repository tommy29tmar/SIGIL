#!/usr/bin/env bash
# hewn-mcp — public alias for the Flint MCP wrapper.

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
target="$script_dir/flint-mcp"

if [ ! -x "$target" ]; then
  echo "hewn-mcp: compatibility wrapper not found: $target" >&2
  exit 1
fi

exec "$target" "$@"
